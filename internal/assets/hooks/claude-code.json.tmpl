{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if ! command -v argus >/dev/null 2>&1; then printf '%s\\n' 'Argus: Please install Argus CLI. See project README for instructions.'; exit 0; fi; exec argus tick --agent claude-code{{ if .Global }} --global{{ end }}",
            "timeout": 10,
            "statusMessage": "Argus"
          }
        ]
      }
    ]
  }
}
