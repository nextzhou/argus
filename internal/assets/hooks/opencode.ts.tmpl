import type { Plugin } from "@opencode-ai/plugin";

export const ArgusPlugin: Plugin = async ({ $, client, directory }) => {
  const pendingInjections = new Map<string, string>();

  return {
    "chat.message": async (input) => {
      try {
        const which = await $`which argus`.cwd(directory).quiet().nothrow();
        if (which.exitCode !== 0) {
          // TODO: replace the generic missing-binary hint with the final OpenCode URL or skill guidance.
          pendingInjections.set(
            input.sessionID,
            "Argus: Please install Argus CLI. See project README for instructions.",
          );
          return;
        }

        const session = await client.session.get({
          path: { id: input.sessionID },
        });
        const payload = JSON.stringify({
          sessionID: input.sessionID,
          parentID: session.data?.parentID,
          cwd: directory,
        });
        const result = await $`echo ${payload} | argus tick --agent opencode{{ if .Global }} --global{{ end }}`
          .cwd(directory)
          .quiet()
          .nothrow();
        const text = result.text().trim();
        if (result.exitCode === 0 && text) {
          pendingInjections.set(input.sessionID, text);
        } else {
          pendingInjections.delete(input.sessionID);
        }
      } catch {
        // Fail open: do not interrupt session on error
      }
    },
    "experimental.chat.messages.transform": async (_input, output) => {
      if (output.messages.length === 0) {
        return;
      }

      let lastUserMessageIndex = -1;
      for (let index = output.messages.length - 1; index >= 0; index -= 1) {
        if (output.messages[index].info.role === "user") {
          lastUserMessageIndex = index;
          break;
        }
      }
      if (lastUserMessageIndex === -1) {
        return;
      }

      const lastUserMessage = output.messages[lastUserMessageIndex];
      const sessionID = lastUserMessage.info.sessionID ?? "";
      if (!sessionID) {
        return;
      }

      const injectedText = pendingInjections.get(sessionID);
      if (!injectedText) {
        return;
      }
      pendingInjections.delete(sessionID);

      const textPartIndex = lastUserMessage.parts.findIndex(
        (part) => part.type === "text" && typeof part.text === "string",
      );
      if (textPartIndex === -1) {
        return;
      }

      lastUserMessage.parts.splice(textPartIndex, 0, {
        id: `synthetic_hook_${Date.now()}`,
        messageID: lastUserMessage.info.id,
        sessionID,
        type: "text",
        text: injectedText,
        synthetic: true,
        // biome-ignore lint/suspicious/noExplicitAny: OpenCode Part typing requires a wider union than the hook output exposes here.
      } as any);
    },
  };
};
