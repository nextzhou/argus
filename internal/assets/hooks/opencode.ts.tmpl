import type { Plugin } from "@anthropic-ai/opencode";

const plugin: Plugin = {
  name: "argus",
  version: "0.1.0",

  hooks: {
    "chat.message": async (input, output) => {
      try {
        const which = await $`which argus`.quiet().nothrow();
        if (which.exitCode !== 0) {
          output.parts.push({
            type: "text",
            text: "Argus: Please install Argus CLI. See project README for instructions.",
            // biome-ignore lint/suspicious/noExplicitAny: required by OpenCode Plugin API type mismatch
          } as any);
          return;
        }
        const payload = JSON.stringify({
          sessionID: input.sessionID,
        });
        const result = await $`echo ${payload} | argus tick --agent opencode{{ if .Global }} --global{{ end }}`
          .quiet()
          .nothrow();
        if (result.exitCode === 0 && result.text().trim()) {
          output.parts.push({
            type: "text",
            text: result.text(),
            // biome-ignore lint/suspicious/noExplicitAny: required by OpenCode Plugin API type mismatch
          } as any);
        }
      } catch {
        // Fail open: do not interrupt session on error
      }
    },
  },
};

export default plugin;
