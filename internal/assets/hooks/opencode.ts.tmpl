import type { Plugin } from "@anthropic-ai/opencode";

const plugin: Plugin = {
  name: "argus",
  version: "0.1.0",

  hooks: {
    "chat.message": async (input, output) => {
      try {
        const payload = JSON.stringify({
          sessionID: input.sessionID,
        });
        const result =
          await $`echo ${payload} | argus tick --agent opencode{{ if .Global }} --global{{ end }}`.quiet().nothrow();
        if (result.exitCode === 0 && result.text().trim()) {
          output.parts.push({
            type: "text",
            text: result.text(),
          } as any);
        }
      } catch {
        // Fail open: do not interrupt session on error
      }
    },

    "tool.execute.before": async (input, output) => {
      try {
        const payload = JSON.stringify({
          tool: input.tool,
          args: output.args,
        });
        const result =
          await $`echo ${payload} | argus trap --agent opencode{{ if .Global }} --global{{ end }}`.quiet().nothrow();
        if (result.exitCode !== 0) {
          return;
        }
        const trapData = JSON.parse(result.text());
        if (
          trapData.hookSpecificOutput?.permissionDecision === "deny"
        ) {
          throw new Error(
            trapData.hookSpecificOutput.permissionDecisionReason ??
              "[Argus] Operation denied",
          );
        }
      } catch (e: any) {
        if (e.message.includes("[Argus]")) throw e;
        // Fail open: JSON parse failure or other error
      }
    },
  },
};

export default plugin;
